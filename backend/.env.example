# Application
NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/hisab
MONGO_DB_NAME=hisab
MONGO_CONNECT_TIMEOUT_MS=5000
MONGO_SOCKET_TIMEOUT_MS=45000
MONGO_MAX_RETRIES=3
MONGO_RETRY_DELAY_MS=2000

# Auth
JWT_SECRET=replace-with-strong-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-strong-random-refresh-secret
REFRESH_TOKEN_SECRET=replace-with-strong-random-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# Trust Optimization (Phase 9)
TRUST_OPTIMIZATION_ENABLED=true
TRUST_OPTIMIZATION_CHECK_INTERVAL_MINUTES=60
TRUST_MONTHLY_RECALIBRATION_DAYS=30
TRUST_QUARTERLY_RETRAIN_DAYS=90
TRUST_MONITORING_SNAPSHOT_PATH=
TRUST_OPTIMIZATION_DATASET_PATH=
TRUST_CALIBRATION_DATASET_PATH=
TRUST_TRAINING_DATASET_PATH=
TRUST_REQUIRE_REAL_DATASET=false
TRUST_ALLOW_SYNTHETIC_DATASET=false
TRUST_MONITORING_MAX_AGE_HOURS=48
TRUST_PYTHON_EXE=..\\.venv\\Scripts\\python.exe
